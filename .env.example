# Binance
# Arquitectura:
# - MAINNET: SOLO datos de mercado (klines/ticker) -> BINANCE_DATA_* (opcional)
# - TESTNET: SOLO ejecución (órdenes/balances/cancel) -> BINANCE_TRADE_* (obligatorio)

# TESTNET (trading) - OBLIGATORIO
BINANCE_TRADE_API_KEY=
BINANCE_TRADE_API_SECRET=

# MAINNET (data) - OPCIONAL (endpoints públicos no requieren key)
BINANCE_DATA_API_KEY=
BINANCE_DATA_API_SECRET=

# Legacy fallback (si no defines BINANCE_TRADE_*, se usarán estas)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Toggle de testnet para clientes legacy (v2/v3). En v3.1 se usa client_trade (TESTNET).
# Valores: true/false
BINANCE_TESTNET=true

# Símbolos (separados por coma)
SYMBOLS=BTCUSDT

# Estrategia
TIMEFRAME=1h
POLL_INTERVAL_SECONDS=30
BUY_COOLDOWN_SECONDS=5400

# --- NUEVO (v3): Entradas y gestión por ATR/EMA ---
# RSI deja de ser trigger y pasa a confirmación (rango).
RSI_CONFIRM_MIN=40
RSI_CONFIRM_MAX=60

# Ventana ATR (volatilidad)
ATR_WINDOW=14

# DCA: desactivado por defecto (evita martingala). Si lo activas, jamás corre en BEAR.
ENABLE_DCA=0

# --- NUEVO (v3): Risk manager por símbolo ---
# Bloquea nuevas entradas si el drawdown del símbolo supera este %.
MAX_SYMBOL_DRAWDOWN_FRAC=0.06

# Bloquea nuevas entradas si el capital comprometido del símbolo supera este % del equity total.
MAX_CAPITAL_COMMITTED_FRAC=0.15

# Si la pérdida realizada del día supera este % del equity de inicio del día: pausa el símbolo 24h.
DAILY_LOSS_LIMIT_FRAC=0.03
SYMBOL_COOLDOWN_AFTER_DAILY_LOSS_SECONDS=86400

# --- LEGACY (compatibilidad / fallback) ---
# Estas variables ya NO gobiernan las entradas principales ni el TP/SL (ahora es por ATR),
# pero se mantienen por compatibilidad con posiciones antiguas y/o fallback si ATR no está.
RSI_THRESHOLD=30
TAKE_PROFIT_PCT=2
STOP_LOSS_PCT=1
TRAILING_TAKE_PROFIT_PCT=0.5
TRAILING_STOP_PCT=0.5
POSITION_SIZE=0.01

# Binance filters (opcional; el bot consulta filtros dinámicamente)
STEP_SIZE=0.00001
MIN_NOTIONAL=10

# Logs
LOG_LEVEL=INFO

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Health endpoint (Flask) (opcional)
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8000

# --- PostgreSQL (OBLIGATORIO) ---
# A partir de v3.1, el bot NO usa CSV para posiciones ni trades.
USE_DATABASE=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme

# Pool/tuning (opcional)
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=8
POSTGRES_CONNECT_TIMEOUT=5

# Equity snapshots: interval en segundos
EQUITY_SNAPSHOT_INTERVAL=300

# --- Risk Layer v2 (institucional) ---
# Kill switch global por drawdown desde el peak de equity
GLOBAL_KILL_SWITCH_ENABLED=true
GLOBAL_MAX_DRAWDOWN_FRAC=0.10

# Circuit breaker: detiene el bot tras N errores críticos consecutivos
MAX_CRITICAL_ERRORS=5

# Reconciliación: parámetros para posiciones RECOVERED (si Binance tiene balance pero DB está vacío)
# Intenta ATR desde trading.market_klines (TIMEFRAME por defecto). Si no hay ATR -> usa STOP_LOSS_PCT/TAKE_PROFIT_PCT.
RECOVERED_ATR_INTERVAL=1h
RECOVERED_ATR_PERIOD=14
RECOVERED_ATR_LIMIT=100
RECOVERED_SL_ATR_MULT=2.0
RECOVERED_TP_ATR_MULT=2.0
RECOVERED_TRAILING_SL_ATR_MULT=2.0

# --- Risk Layer v3 (modular, opcional, fail-open) ---
# Integración en apertura de nuevas posiciones (NO altera la lógica de estrategia).
# Si un componente falla internamente, el bot continúa (modo fail-open).

# 1) Volatility Adjusted Position Sizing (ATR)
# Fórmula: position_size_usdt = (equity_total * RISK_PER_TRADE_FRAC) / (atr * POSITION_SIZER_ATR_MULTIPLIER)
# Luego se limita por MAX_POSITION_CAP_FRAC y MIN_POSITION_USDT.
RISK_V3_POSITION_SIZER_ENABLED=false
RISK_PER_TRADE_FRAC=0.01
MAX_POSITION_CAP_FRAC=0.10
MIN_POSITION_USDT=10.0
POSITION_SIZER_ATR_MULTIPLIER=1.0
POSITION_SIZER_ATR_WINDOW=14

# 2) Correlation Exposure Control
# Usa retornos logarítmicos rolling para correlación entre símbolos.
# Si corr > CORRELATION_THRESHOLD, limita exposición combinada del cluster correlacionado.
RISK_V3_CORRELATION_ENABLED=false
CORRELATION_WINDOW_DAYS=30
CORRELATION_THRESHOLD=0.8
CORRELATION_MAX_COMBINED_EXPOSURE_FRAC=0.25
CORRELATION_INTERVAL=1d
CORRELATION_CACHE_SECONDS=300

# 3) Intraday VaR Limit
# VaR histórico con retornos diarios sobre equity snapshots.
# Si VaR estimado > MAX_VAR_FRAC, bloquea nuevas entradas.
RISK_V3_VAR_ENABLED=false
VAR_WINDOW_DAYS=30
VAR_CONFIDENCE=0.95
MAX_VAR_FRAC=0.05
VAR_CACHE_SECONDS=300

# 4) Slippage Monitor
# slippage = abs(fill_price - expected_price) / expected_price
# Si supera SLIPPAGE_MAX_FRAC, registra evento; N consecutivos activan STOP_EVENT.
RISK_V3_SLIPPAGE_ENABLED=false
SLIPPAGE_MAX_FRAC=0.005
SLIPPAGE_MAX_CONSECUTIVE=3

# 5) Equity Regime Filter
# Evalúa EMA rápida/lenta del equity diario:
# - mode=reduce: reduce tamaño por EQUITY_REGIME_REDUCTION_FRAC cuando EMA_FAST < EMA_SLOW
# - mode=block: bloquea nuevas entradas cuando EMA_FAST < EMA_SLOW
RISK_V3_EQUITY_REGIME_ENABLED=false
EQUITY_REGIME_MODE=reduce
EQUITY_REGIME_REDUCTION_FRAC=0.5
EQUITY_EMA_FAST=50
EQUITY_EMA_SLOW=200
EQUITY_REGIME_CACHE_SECONDS=300

# --- Market data (klines) -> PostgreSQL (OBLIGATORIO) ---
# Backfill inicial si no existe histórico (máx 1000 por llamada en Binance)
KLINES_BACKFILL_LIMIT=1000

# Paginación máxima cuando hay que ponerse al día
KLINES_MAX_PAGES=20

# Overlap (en velas) para evitar gaps por velas “tardías”; dupes se ignoran por PK
KLINES_OVERLAP_CANDLES=2

# Opcionales (Market Data Process): control de rango histórico
# - KLINES_HISTORY_LOOKBACK ejemplo: 7d, 30d, 180d (según soporte en tu servicio de sync)
# - KLINES_START_TIME / KLINES_END_TIME en ISO8601, ej: 2026-01-01T00:00:00Z
KLINES_HISTORY_LOOKBACK=
KLINES_START_TIME=
KLINES_END_TIME=

# --- Market Data Process (proceso separado; NO trading) ---
# Si no se definen, usa SYMBOLS y TIMEFRAME del bot.
MARKET_DATA_SYMBOLS=BTCUSDT
MARKET_DATA_INTERVALS=1h
MARKET_DATA_SYNC_EVERY_SECONDS=30

#Si está activo y detecta locked>0, intenta cancelar órdenes abiertas 
#del símbolo antes de reintentar vender.
CANCEL_OPEN_ORDERS_ON_STOP=1

# ── Multi-Strategy Engine ──────────────────────────────────────────────────
STRATEGY_MODE=MAJORITY
TREND_SYMBOLS=BTCUSDT,ETHUSDT
TREND_ADX_MIN=25
TREND_EMA_FAST=50
TREND_EMA_SLOW=200
TREND_RSI_MIN=35
TREND_RSI_MAX=65
TREND_POSITION_SIZE=0.08
MEAN_REV_SYMBOLS=RE:^(?!BTC|ETH).+USDT$
MEAN_REV_RSI_OS=30
MEAN_REV_BB_WINDOW=20
MEAN_REV_POSITION_SIZE=0.04
FUNDING_SYMBOLS=BTCUSDT,ETHUSDT
FUNDING_THRESHOLD=0.0005
FUNDING_POSITION_SIZE=0.05
VOL_BREAKOUT_LOOKBACK=20
VOL_BREAKOUT_ATR_MULT=1.5
VOL_BREAKOUT_VOL_MULT=1.2
VOL_BREAKOUT_POSITION_SIZE=0.06
VOL_BREAKOUT_BB_LAG=3

# ── ML model (v5) ──────────────────────────────────────────────────────────
ML_MODEL_PATH=artifacts/model_momentum_v4_phase2.joblib
ML_PROB_THRESHOLD=0.60

# ── PortfolioManager (multi-estrategia v2) ────────────────────────────────
# Score mínimo ponderado (weight × confidence) para aprobar BUY/SELL
PORTFOLIO_BUY_THRESHOLD=1.0
PORTFOLIO_SELL_THRESHOLD=1.0
# true = cualquier HOLD veta la entrada (conservador). false = recomendado con modo híbrido
PORTFOLIO_VETO_ON_HOLD=false

# ── ML Modo Híbrido: ML como escalador de posición (recomendado) ──────────
# Backtest 2022-2025: reduce drawdown 39-53% vs filtro binario en todos los regímenes
ML_HYBRID_MODE=true
ML_HYBRID_STRATEGY_ID=ml_momentum
ML_MIN_CONFIDENCE=0.40       # gate mínimo: conf < 0.40 → no entra
ML_SIZE_SCALE_LOW=0.5        # conf [0.40, 0.55) → base_size × 0.5
ML_SIZE_SCALE_MID=1.0        # conf [0.55, 0.70) → base_size × 1.0
ML_SIZE_SCALE_HIGH=1.5       # conf ≥ 0.70       → base_size × 1.5
